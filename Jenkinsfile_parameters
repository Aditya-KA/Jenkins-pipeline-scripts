pipeline {
    agent none

    parameters {
        string(name: 'Name', defaultValue: 'Bantu', description: 'Enter your name' )
        text(name: 'Biography', defaultValue: 'Hi', description: 'Enter min 30 words')
        choice(name: 'Choose', choices: ['test','QA', 'pre-prod', 'Prod'],description: 'Select one' )
        booleanParam(name: 'Checkout', defaultValue: false, description: 'Please check box if required')
    }

    stages {
        stage('stage-1'){
            agent {label 'Slave_1'}

            steps {
                echo "Name: ${params.Name}"
                echo "Biography: ${params.Biography}"
                echo "Choose: ${params.Choose}"
                echo "boolValue: ${params.checkout}"

            }
        }
    }
}